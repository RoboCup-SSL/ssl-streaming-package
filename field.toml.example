# Per-field config — one per field PC. Copy to field.toml in the repo root and edit.
# This is the ONLY file you change per field; `./run.sh` reads it.
#
# The overlay has no source mapping: name your OBS Text and Image sources to match the
# canonical field names listed in obs-template/README.md (e.g. "blue_name", "stage_time",
# "blue_logo"). Sources you don't create are simply not shown.

[field]
name = "A"

[game_controller]
address = "224.5.23.1"
port = 10003

# Cameras for this field, fed through MediaMTX (see services/mediamtx-controller).
# Fixed endpoint names: commentator, field-1..field-4. Declare only what this field has.
# Descriptors: rtsp://… | usb:<device> | ts:<url>. Used by mediamtx-controller, not obs-live-data.
[cameras]
commentator = "usb:/dev/video0"
field-1 = "rtsp://10.0.0.5:554/stream"

[obs]
url = "ws://localhost:4455"
password = "change-me"
text_field = "text"   # FreeType2 text source on Linux uses "text"
# logos_dir: leave unset to use the bundled team logos. Set a path only to override
# (relative paths resolve next to this file).

# stage_dir: leave empty when OBS runs on THIS machine (the normal field deployment).
# Only needed when OBS is on another machine: set a path, and mirror the same folder
# (copy logos/ into it) on the OBS box so the absolute paths line up. e.g. "/tmp/ssl-logos"
stage_dir = ""

[schedule]
path = "data/schedule.json"
