# Per-field config — one per field PC. Copy to field.toml in the repo root and edit.
# This is the ONLY file you change per field; `./run.sh` reads it.
#
# IMPORTANT: every name under [obs.sources] and [obs.images] must match a source you
# created in OBS *exactly*. A name with no matching OBS source is silently ignored
# (the run still works, that value just never appears). The demo's preflight lists your
# actual OBS inputs and flags any configured name that doesn't exist.

[field]
name = "A"

[game_controller]
address = "224.5.23.1"
port = 10003

# Cameras for this field, fed through MediaMTX (see services/mediamtx-controller).
# Fixed endpoint names: commentator, field-1..field-4. Declare only what this field has.
# Descriptors: rtsp://… | usb:<device> | ts:<url>. Used by mediamtx-controller, not obs-live-data.
[cameras]
commentator = "usb:/dev/video0"
field-1 = "rtsp://10.0.0.5:554/stream"

[obs]
url = "ws://localhost:4455"
password = "change-me"
text_field = "text"   # FreeType2 text source on Linux uses "text"
# logos_dir: leave unset to use the bundled team logos. Set a path only to override
# (relative paths resolve next to this file).

# stage_dir: leave empty when OBS runs on THIS machine (the normal field deployment).
# Only needed when OBS is on another machine: set a path, and mirror the same folder
# (copy logos/ into it) on the OBS box so the absolute paths line up. e.g. "/tmp/ssl-logos"
stage_dir = ""

# --- Text sources: logical field -> the OBS Text source name showing it ---
# Create one OBS "Text" source per line below (or delete lines you don't want shown).
[obs.sources]
blue_name = "txt_blue_name"
blue_score = "txt_blue_score"
yellow_name = "txt_yellow_name"
yellow_score = "txt_yellow_score"
stage = "txt_stage"
next_match = "txt_next_match"
countdown = "txt_countdown"

# --- Image sources: logical field -> the OBS Image source name showing the team logo ---
# Create one OBS "Image" source per line. Omit this whole block to skip logos.
[obs.images]
blue_logo = "img_blue_logo"
yellow_logo = "img_yellow_logo"

[schedule]
path = "data/schedule.json"
