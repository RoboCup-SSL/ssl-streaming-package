# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Local reference material / things we derive from but don't commit
_resources/

# Per-deployment field config (holds OBS password); commit field.toml.example instead
field.toml

# Per-event YouTube config; commit youtube.toml.example instead
youtube.toml

# Downloaded / generated at deploy time
bin/
mediamtx.yml
mediamtx.log
# Self-signed certs MediaMTX may write to cwd (we disable the servers that need them)
auto.crt
auto.key

# OBS profile stream config — holds the per-field stream key; commit service.json.example only
obs-template/**/profile/service.json

# YouTube Data API OAuth credentials (services/youtube) — never commit
**/client_secret.json
**/youtube_token.json
# Per-match RTMP stream keys emitted by youtube.schedule — secrets, never commit
**/stream_keys.json

# Ad-hoc backups — not tracked
services/obs_live_data/logos_backup.zip
*_backup.svg

# Generated thumbnail outputs — regenerate with generate_thumbnails.py
services/obs_live_data/youtube_thumbnails/png/
services/obs_live_data/youtube_thumbnails/svg/
services/obs_live_data/youtube_thumbnails/jpg/
