# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Local reference material / things we derive from but don't commit
_resources/

# Per-deployment field config (holds OBS password); commit field.toml.example instead
field.toml

# Downloaded / generated at deploy time
bin/
mediamtx.yml
mediamtx.log
# Self-signed certs MediaMTX may write to cwd (we disable the servers that need them)
auto.crt
auto.key
